AWS_REGION=us-east-1
API_BASE_URL_DEV=https://api-dev.gazellecoffee.com/v1
API_BASE_URL_STAGING=https://api-staging.gazellecoffee.com/v1
API_BASE_URL_PROD=https://api.gazellecoffee.com/v1
EXPO_PUBLIC_API_BASE_URL=http://127.0.0.1:8080/v1
DATABASE_URL='postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres?sslmode=require'
# Run migrations manually: pnpm --filter @gazelle/persistence migrate
CATALOG_SERVICE_BASE_URL=http://127.0.0.1:3002
GATEWAY_INTERNAL_API_TOKEN=
GATEWAY_UPSTREAM_TIMEOUT_MS=5000
GATEWAY_RATE_LIMIT_WINDOW_MS=60000
GATEWAY_RATE_LIMIT_AUTH_WRITE_MAX=24
GATEWAY_RATE_LIMIT_AUTH_READ_MAX=120
GATEWAY_RATE_LIMIT_CATALOG_READ_MAX=180
GATEWAY_RATE_LIMIT_ORDERS_READ_MAX=120
GATEWAY_RATE_LIMIT_ORDERS_WRITE_MAX=60
GATEWAY_RATE_LIMIT_CHECKOUT_MAX=20
GATEWAY_RATE_LIMIT_LOYALTY_READ_MAX=120
GATEWAY_RATE_LIMIT_PUSH_TOKEN_MAX=30
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Gazelle
PASSKEY_EXPECTED_ORIGINS=https://localhost
PASSKEY_TIMEOUT_MS=60000
# Set the same JWT_SECRET on identity and gateway to enable locally verified JWT access tokens.
# Use at least 32 characters. Example: openssl rand -base64 48
# When unset, access tokens fall back to the legacy opaque-token path.
JWT_SECRET=
APPLE_SIGN_IN_VERIFY=false
IDENTITY_RATE_LIMIT_WINDOW_MS=60000
IDENTITY_RATE_LIMIT_AUTH_WRITE_MAX=24
IDENTITY_RATE_LIMIT_AUTH_READ_MAX=120
IDENTITY_RATE_LIMIT_PASSKEY_CHALLENGE_MAX=24
IDENTITY_RATE_LIMIT_PASSKEY_VERIFY_MAX=12
MAIL_PROVIDER=log
RESEND_API_KEY=
MAGIC_LINK_BASE_URL=http://localhost:8080
MAGIC_LINK_EXPIRY_MINUTES=15
# Clover live/sandbox mode:
# - leave CLOVER_PROVIDER_MODE=simulated for normal local development
# - switch to live only when all Clover vars below are configured together on the payments service
# - Use either direct merchant ecommerce credentials or the Clover OAuth app flow below
# - CLOVER_BEARER_TOKEN is the Clover Bearer credential used for /v1/charges and /v1/refunds
#   This can be a merchant private ecommerce token; when Clover OAuth is connected, the stored OAuth access token overrides it
# - CLOVER_API_ACCESS_KEY is the Clover public apiAccessKey used for /v1/tokens tokenization requests
#   When Clover OAuth is connected, the stored PAKMS/apiAccessKey overrides it
# - example sandbox charge endpoint: https://scl-sandbox.dev.clover.com/v1/charges
# - example sandbox refund endpoint: https://scl-sandbox.dev.clover.com/v1/refunds
# - CLOVER_APPLE_PAY_TOKENIZE_ENDPOINT and an apiAccessKey are only required for applePayWallet requests; plain applePayToken charges do not use them
CLOVER_PROVIDER_MODE=simulated
CLOVER_BEARER_TOKEN=
CLOVER_API_KEY=
CLOVER_API_ACCESS_KEY=
CLOVER_MERCHANT_ID=
CLOVER_OAUTH_ENVIRONMENT=sandbox
CLOVER_APP_ID=
CLOVER_APP_SECRET=
CLOVER_OAUTH_REDIRECT_URI=
CLOVER_OAUTH_STATE_SECRET=
CLOVER_OAUTH_AUTHORIZE_ENDPOINT=
CLOVER_OAUTH_TOKEN_ENDPOINT=
CLOVER_OAUTH_REFRESH_ENDPOINT=
CLOVER_OAUTH_PAKMS_ENDPOINT=
CLOVER_CHARGE_ENDPOINT=
CLOVER_REFUND_ENDPOINT=
CLOVER_APPLE_PAY_TOKENIZE_ENDPOINT=
CLOVER_WEBHOOK_SHARED_SECRET=
ORDERS_SERVICE_BASE_URL=http://127.0.0.1:3001
ORDERS_INTERNAL_API_TOKEN=
